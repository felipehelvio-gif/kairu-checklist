{
  "name": "kairu-checklist",
  "version": "1.0.0",
  "description": "Checklist Operacional Inteligente com IA — by Kairu Labs",
  "main": "main.js",
  "author": "Kairu Labs",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.kairulabs.checklist",
    "productName": "Kairu Checklist",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "KairuLabs",
        "repo": "kairu-checklist"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "mobile.html",
      "templates.js",
      "ai-engine.js",
      "whatsapp.js",
      "database.js",
      "kairu-sdk.js",
      "assets/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kairu Checklist"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.business"
    }
  },
  "devDependencies": {
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4"
  }
}
